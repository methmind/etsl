{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 2,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "clang-debug",
      "displayName": "Clang Debug (Ninja)",
      "description": "MSYS2/MinGW clang++ with Ninja, debug symbols, warnings",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/cmake-build-debug-clang",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-Wall -Wextra -fno-exceptions -fno-rtti"
      }
    },
    {
      "name": "clang-minsize",
      "displayName": "Clang MinSizeRel (Ninja)",
      "description": "MSYS2/MinGW clang++ size-optimized baseline (ADR-9)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/cmake-build-minsize-clang",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "MinSizeRel",
        "CMAKE_CXX_FLAGS": "-Os -ffunction-sections -fdata-sections -fno-exceptions -fno-rtti -flto -Wall -Wextra",
        "CMAKE_EXE_LINKER_FLAGS": "-Wl,--gc-sections -s"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "clang-debug",
      "configurePreset": "clang-debug"
    },
    {
      "name": "clang-minsize",
      "configurePreset": "clang-minsize"
    }
  ]
}
